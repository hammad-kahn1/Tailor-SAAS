# Used by docker-compose.yml for the MySQL container and to template
# backend/.env (copy backend/.env.example -> backend/.env and keep these in sync).

DB_DATABASE=tailor_saas
DB_USERNAME=tailor_user
DB_PASSWORD=secret
DB_ROOT_PASSWORD=rootsecret

# Set to true only for the FIRST `docker compose up` to seed demo data.
SEED_DEMO_DATA=false

VITE_API_BASE_URL=/api/v1
