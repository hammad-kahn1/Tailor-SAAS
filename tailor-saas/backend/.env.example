APP_NAME="TailorSaaS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_PORT=8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ── Database ──────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=tailor_saas
DB_USERNAME=root
DB_PASSWORD=

# ── Cache / Queue / Session ───────────────────────────
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# ── Mail (MailHog for local dev) ──────────────────────
MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="no-reply@tailorsaas.com"
MAIL_FROM_NAME="${APP_NAME}"

# ── Sanctum ───────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=localhost:5173,127.0.0.1:5173

# ── Frontend ──────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
