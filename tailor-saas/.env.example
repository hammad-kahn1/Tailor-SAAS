# ─── Compose-level variables ──────────────────────────────────────────────────
# Copy to .env and fill in your values before running `docker compose up --build`

# Database
DB_DATABASE=tailor_saas
DB_USERNAME=tailor_user
DB_PASSWORD=secret
DB_ROOT_PASSWORD=rootsecret
DB_EXTERNAL_PORT=3306

# Backend
APP_KEY=                         # auto-generated on first boot
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000

# Seeding
SEED_DEMO_DATA=true              # set to true on first run to load sample data

# Frontend build-time
VITE_API_BASE_URL=http://localhost:8000/api/v1

# Mail (MailHog for local dev)
MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_FROM_ADDRESS=no-reply@tailorsaas.com
